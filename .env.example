# ArenaMind AI - Environment Variables Template
# Copy this file to .env and configure the actual values before running the application

# Application Port
PORT=3000

# Environment Mode (development | production | test)
NODE_ENV=development

# Google Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration
DATABASE_URL=mongodb://localhost:27017/arenamind

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
