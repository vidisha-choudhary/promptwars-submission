{
  "name": "arenamind-ai",
  "version": "1.0.0",
  "private": true,
  "description": "ArenaMind AI - GenAI platform for stadium operations, fan experience, and organizer decisions",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit && tsc --noEmit -p client/tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run format:check"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.5.0",
    "typescript": "^5.7.3"
  }
}
